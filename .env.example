# Copy to .env and fill in values. Never commit .env.

# Core
NODE_ENV=development
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql+asyncpg://plate:plate@localhost:5432/plate_clean
DATABASE_URL_SYNC=postgresql://plate:plate@localhost:5432/plate_clean
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=change_me_min_32_chars_change_me_min_32_chars
JWT_EXPIRY_HOURS=24
OTP_PROVIDER=console   # 'console' (dev), 'msg91', or 'twilio'
OTP_API_KEY=

# Object storage
S3_ENDPOINT=http://localhost:9000   # MinIO in dev, leave blank for AWS
S3_REGION=us-east-1
S3_BUCKET=plate-clean-images
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_BASE_URL=http://localhost:9000

# Vision (Phase 1)
ANTHROPIC_API_KEY=
VISION_MODEL=claude-sonnet-4-5
VISION_TIMEOUT_SECONDS=30

# Vision (Phase 2)
VISION_SERVICE_URL=http://localhost:8001
VISION_SERVICE_TIMEOUT_SECONDS=15

# Fraud
GEOFENCE_DEFAULT_RADIUS_M=100
GEOFENCE_MODE=warn   # 'warn' or 'block'
MAX_SESSIONS_PER_USER_PER_DAY=3
MAX_CAPTURES_PER_HOUR=10
MAX_REWARDS_PER_RESTAURANT_PER_DAY=1

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_SENTRY_DSN=
