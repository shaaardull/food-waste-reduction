# Copy to .env and fill in values. Never commit .env.

# Core
NODE_ENV=development
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql+asyncpg://plate:plate@localhost:5432/plate_clean
DATABASE_URL_SYNC=postgresql://plate:plate@localhost:5432/plate_clean
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=change_me_min_32_chars_change_me_min_32_chars
JWT_EXPIRY_HOURS=24
OTP_PROVIDER=console   # 'console' (dev), 'msg91', or 'twilio'
OTP_API_KEY=

# Bill-delivery email (Gap-D). Console mode logs the rendered receipt
# to stdout — the dev default. Flip to 'smtp' + fill credentials to
# send for real. NEVER commit a real SMTP_PASSWORD — put it in your
# local apps/api/.env (gitignored).
EMAIL_MODE=console      # 'console' (dev) or 'smtp'
SMTP_HOST=smtp.zoho.in
SMTP_PORT=587
SMTP_USER=              # e.g. noreply-platecleanrewards@superpositionlabs.co.in
SMTP_PASSWORD=          # Zoho App Password (Settings → Security → App Passwords)
SMTP_STARTTLS=true
EMAIL_FROM_NAME=Plate-Clean Rewards
EMAIL_FROM_ADDRESS=     # blank = same as SMTP_USER

# Object storage
S3_ENDPOINT=http://localhost:9000   # MinIO in dev, leave blank for AWS
S3_REGION=us-east-1
S3_BUCKET=plate-clean-images
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_BASE_URL=http://localhost:9000

# Vision (Phase 1)
ANTHROPIC_API_KEY=
VISION_MODEL=claude-sonnet-4-5
VISION_TIMEOUT_SECONDS=30

# Vision (Phase 2)
# Flip USE_VISION_SERVICE=true once services/vision is up to route the
# Celery scoring task through the standalone microservice instead of the
# in-process Anthropic call.
USE_VISION_SERVICE=false
VISION_SERVICE_URL=http://localhost:8001
VISION_SERVICE_TIMEOUT_SECONDS=30
# services/vision backend selector — 'stub', 'anthropic', or 'yolo'.
VISION_BACKEND=stub

# Fraud
GEOFENCE_DEFAULT_RADIUS_M=100
GEOFENCE_MODE=warn   # 'warn' or 'block'
MAX_SESSIONS_PER_USER_PER_DAY=3
MAX_CAPTURES_PER_HOUR=10
MAX_REWARDS_PER_RESTAURANT_PER_DAY=1

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_SENTRY_DSN=
