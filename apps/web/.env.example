# Base URL for the Plate-Clean API.
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Google Identity Services OAuth Client ID. When empty the Google
# button still renders but backend responds 503 and the UI shows a
# "not set up yet" message. Provision at
# https://console.cloud.google.com → Credentials → Create OAuth
# Client ID → Web application. Add these Authorized JavaScript
# origins in the console UI:
#   http://localhost:5173    (diner PWA dev)
#   http://localhost:5174    (staff dashboard dev)
#   http://localhost:5175    (marketing dev)
#   https://plateclean.in   (or your prod domain)
#
# You do NOT need a client secret for GIS ID-token flow — leaving
# it in your Google Cloud project is fine and safe.
VITE_GOOGLE_CLIENT_ID=
