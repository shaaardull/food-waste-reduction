# URL of the diner PWA. In dev this is the Vite server on 5173.
# In prod, point at the diner subdomain (e.g. https://app.plate-clean.app).
VITE_DINER_URL=http://localhost:5173

# URL of the staff dashboard. In dev this is 5174. In prod, point at
# the dashboard subdomain (e.g. https://dashboard.plate-clean.app).
VITE_DASHBOARD_URL=http://localhost:5174

# Contact address surfaced in the "Talk to us" CTAs.
VITE_CONTACT_EMAIL=hello-platecleanrewards@superpositionlabs.co.in
